{
  "name": "@lidofinance/multi-semantic-release",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": {
    "multi-semantic-release": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepare": "git config core.hooksPath .git-hooks || echo 'Not in a git repo'"
  },
  "homepage": "https://github.com/lidofinance/multi-semantic-release/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lidofinance/multi-semantic-release.git",
    "directory": "./"
  },
  "bugs": {
    "url": "https://github.com/lidofinance/multi-semantic-release/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "semantic-release",
    "multi-semantic-release"
  ],
  "license": "MIT",
  "engines": {
    "node": "^22.14.0 || >=24.10.0"
  },
  "files": [
    "dist/**/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/prompt": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "lint-staged": "17",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "6",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@semrel-extra/topo": "^1.14.1",
    "@types/git-log-parser": "^1.2.3",
    "@types/semver": "^7.7.0",
    "chalk": "^5.4.1",
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.0",
    "detect-indent": "^7.0.1",
    "detect-newline": "^4.0.1",
    "execa": "^9.6.0",
    "git-log-parser": "^1.2.1",
    "lodash-es": "^4.17.21",
    "semantic-release": "^25.0.5",
    "semver": "^7.7.1",
    "winston": "^3.17.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "./**/*.{ts,tsx,css,md,json}": [
      "prettier --write"
    ]
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "develop",
        "channel": "alpha",
        "prerelease": "alpha"
      }
    ]
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
