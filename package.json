{
  "name": "@lidofinance/multi-semantic-release",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": {
    "multi-semantic-release": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "types": "tsc --noEmit",
    "test": "echo 'No tests yet'",
    "clean": "rm -rf dist",
    "prepare": "git config core.hooksPath .git-hooks || echo 'Not in a git repo'"
  },
  "keywords": [
    "semantic-release",
    "multi-semantic-release"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/prompt": "^19.8.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.1.0",
    "@types/semantic-release": "^21.1.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@semrel-extra/topo": "^1.14.1",
    "@types/git-log-parser": "^1.2.3",
    "@types/semver": "^7.7.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "cosmiconfig": "^9.0.0",
    "detect-indent": "^7.0.1",
    "detect-newline": "^4.0.1",
    "git-log-parser": "^1.2.1",
    "lodash-es": "^4.17.21",
    "semantic-release": "^24.2.7",
    "winston": "^3.17.0"
  },
  "lint-staged": {
    "./**/*.{ts,tsx}": [
      "eslint --ignore-path .gitignore --max-warnings=0"
    ],
    "./**/*.{ts,tsx,css,md,json}": [
      "prettier --write"
    ]
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "develop",
        "channel": "alpha",
        "prerelease": "alpha"
      }
    ]
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
